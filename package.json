{
  "name": "harness-ts",
  "version": "0.1.0",
  "description": "TypeScript constructs that synthesize into Harness.io pipeline YAML",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "tsc -p tsconfig.build.json"
  },
  "keywords": [
    "harness",
    "harness.io",
    "pipeline",
    "ci-cd",
    "yaml",
    "constructs",
    "infrastructure-as-code"
  ],
  "author": "Kris V",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kris-vuk/harness-ts.git"
  },
  "homepage": "https://github.com/kris-vuk/harness-ts#readme",
  "bugs": {
    "url": "https://github.com/kris-vuk/harness-ts/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "ajv": "^8.20.0",
    "constructs": "^10.6.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
