  "description": "TypeScript constructs that synthesize Harness.io pipeline YAML",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "tsc -p tsconfig.build.json"
  },
  "keywords": [],
